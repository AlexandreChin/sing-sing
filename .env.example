# LLM Provider (choose one or both)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Search provider — free options require no key:
#   duckduckgo  (no key, rate-limited by IP)
#   hackernews  (unlimited, via Algolia API)
#   reddit      (public JSON API, no key)
#   gnews       (100 req/day free; set key for more)
# Registration required (set SEARCH_API_KEY):
#   newsapi | brave | serper | tavily
SEARCH_API_PROVIDER=duckduckgo
SEARCH_API_KEY=your_search_api_key_here
